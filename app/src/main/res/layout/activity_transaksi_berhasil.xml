<?xml version="1.0" encoding="utf-8"?>
<!-- Layout Konfirmasi setelah Transaksi Berhasil dilakukan -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#FFFFFF">

    <!-- Ikon Centang atau Keberhasilan -->
    <ImageView
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/abc_ic_commit_search_api_mtrl_alpha"
        app:tint="#4CAF50"
        android:layout_marginBottom="24dp"/>

    <!-- Teks Judul Status -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Transaksi Berhasil!"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:layout_marginBottom="8dp"/>

    <!-- Menampilkan waktu transaksi -->
    <TextView
        android:id="@+id/tvWaktuBerhasil"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="12 Oktober 2023, 14:30"
        android:textSize="16sp"
        android:textColor="#757575"
        android:layout_marginBottom="48dp"/>

    <!-- Tombol untuk mencetak bukti pembayaran (Struk) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCetakStruk"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="CETAK STRUK"
        android:layout_marginBottom="12dp"/>

    <!-- Tombol untuk mengakhiri alur transaksi dan kembali ke Dashboard -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSelesai"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="KEMBALI KE DASHBOARD"/>

</LinearLayout>
