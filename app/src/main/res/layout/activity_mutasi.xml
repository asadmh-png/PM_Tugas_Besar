<?xml version="1.0" encoding="utf-8"?>
<!-- Root Layout: Menggunakan LinearLayout vertikal untuk menyusun elemen dari atas ke bawah -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F2F5">

    <!-- Header: Toolbar dengan judul Mutasi Barang dan tombol navigasi kembali -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarMutasi"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/white"
        app:navigationIcon="@drawable/abc_ic_ab_back_material"
        app:title="Mutasi Barang (TO / TI)"
        app:titleTextColor="#333333" />

    <!-- ScrollView: Memastikan form tetap bisa diakses jika layar HP penuh -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Label Petunjuk: Memberitahu user untuk memilih jenis mutasi -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pilih Jenis Aksi:"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <!-- Pilihan Jenis Mutasi: Kirim Barang (Transfer Out) atau Terima Barang (Transfer In) -->
            <RadioGroup
                android:id="@+id/rgJenisMutasi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <RadioButton
                    android:id="@+id/rbKirim"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kirim Barang (TO)"
                    android:layout_weight="1"/>

                <RadioButton
                    android:id="@+id/rbTerima"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Terima Barang (TI)"
                    android:layout_weight="1"/>
            </RadioGroup>

            <!-- Form Dinamis: Area ini akan muncul setelah salah satu RadioButton dipilih -->
            <LinearLayout
                android:id="@+id/layoutFormMutasi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Dropdown Toko Tujuan: Hanya muncul jika memilih 'Kirim Barang' -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilTokoTujuan"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Pilih Toko Tujuan"
                    app:boxStrokeColor="@color/primary_blue"
                    app:hintTextColor="@color/primary_blue"
                    android:layout_marginBottom="16dp"
                    android:visibility="gone">
                    <AutoCompleteTextView
                        android:id="@+id/actvTokoTujuan"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/black"
                        android:inputType="none"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Input Nomor Resi: Hanya muncul jika memilih 'Terima Barang' -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilNomorResi"
                    style="@style/Widget.App.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Nomor Resi Pengiriman"
                    android:layout_marginBottom="16dp"
                    android:visibility="gone">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etNomorResi"
                        style="@style/Widget.App.TextInputEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Input Barcode: Untuk mendata barang apa yang dimutasi -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.App.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Scan Barcode / Kode Barang"
                    android:layout_marginBottom="16dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etBarcodeMutasi"
                        style="@style/Widget.App.TextInputEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Input Jumlah: Berapa banyak barang yang dipindahkan -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.App.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Jumlah (Qty)"
                    android:layout_marginBottom="24dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etQtyMutasi"
                        style="@style/Widget.App.TextInputEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Tombol Eksekusi: Untuk memproses data mutasi ke server -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnProsesMutasi"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:text="PROSES MUTASI"
                    android:textSize="16sp"
                    android:enabled="false"/>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>