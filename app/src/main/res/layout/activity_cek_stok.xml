<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Cek Stok Barang"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp"/>

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Scan Barcode / Ketik Kode Barang"
        android:layout_marginBottom="16dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etBarcodeCek"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"/>
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCariStok"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="CARI BARANG"
        android:layout_marginBottom="24dp"/>

    <LinearLayout
        android:id="@+id/layoutHasilStok"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:background="#F5F5F5"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvNamaBarangCek"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nama Barang"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvHargaBarang"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Harga: Rp 0"
            android:textSize="16sp"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sisa Stok di Toko Ini:"
            android:textSize="14sp"/>

        <TextView
            android:id="@+id/tvJumlahStok"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="15 Pcs"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#1976D2"/>
    </LinearLayout>

</LinearLayout>