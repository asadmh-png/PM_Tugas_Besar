<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Pilih Metode Pembayaran" android:textSize="18sp" android:textStyle="bold" android:gravity="center" android:layout_marginBottom="24dp"/>

    <Button android:id="@+id/btnCash" android:layout_width="match_parent" android:layout_height="60dp" android:text="CASH (TUNAI)"/>
    <Button android:id="@+id/btnNonCash" android:layout_width="match_parent" android:layout_height="60dp" android:text="NON-CASH (QRIS/EDC)"/>
</LinearLayout>