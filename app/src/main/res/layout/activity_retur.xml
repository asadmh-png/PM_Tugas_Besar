<?xml version="1.0" encoding="utf-8"?>
<!-- Root Layout: Menggunakan LinearLayout vertikal sebagai wadah utama halaman Retur -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F2F5">

    <!-- Header: Toolbar untuk judul "Retur Penjualan" dan tombol kembali -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarRetur"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/white"
        app:navigationIcon="@drawable/abc_ic_ab_back_material"
        app:title="Retur Penjualan"
        app:titleTextColor="#333333" />

    <!-- Kontainer Konten: Area untuk input dan hasil pencarian nota -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Input Nomor Nota: Tempat mengetik nomor struk yang akan diretur -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.App.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Masukkan Nomor Nota / Struk Asli"
            android:layout_marginBottom="16dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etNomorNota"
                style="@style/Widget.App.TextInputEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Tombol Cari: Untuk memvalidasi nomor nota ke sistem -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCariNota"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="CARI NOTA"
            android:textSize="16sp"
            android:layout_marginBottom="24dp"/>

        <!-- Garis Pemisah (Divider) -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginBottom="16dp"/>

        <!-- Layout Hasil: Bagian ini akan muncul otomatis jika nota ditemukan (Visibility GONE di awal) -->
        <LinearLayout
            android:id="@+id/layoutHasilRetur"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Label Status Ditemukan -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Data Nota Ditemukan!"
                android:textColor="#388E3C"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <!-- Area Informasi Detail Barang yang ada di Nota tersebut -->
            <TextView
                android:id="@+id/tvDetailNota"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Detail Nota..."
                android:layout_marginBottom="8dp"/>

            <!-- ScrollView & Container: Tempat menampilkan daftar barang secara dinamis -->
            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="16dp">
                <LinearLayout
                    android:id="@+id/containerItemsRetur"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>
            </ScrollView>

            <!-- Input Alasan: Alasan mengapa barang dikembalikan (misal: cacat) -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.App.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Alasan Retur (Cacat/Tukar Ukuran)"
                android:layout_marginBottom="16dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etAlasanRetur"
                    style="@style/Widget.App.TextInputEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textMultiLine"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Tombol Eksekusi: Proses akhir untuk update stok dan keuangan -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnProsesRetur"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="PROSES RETUR BARANG"
                android:backgroundTint="#D32F2F"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>