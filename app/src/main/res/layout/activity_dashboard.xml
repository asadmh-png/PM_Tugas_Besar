<?xml version="1.0" encoding="utf-8"?>
<!-- Root Layout: ScrollView memungkinkan pengguna untuk menggeser layar jika konten melebihi tinggi layar HP -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F5"
    android:fillViewport="true">

    <!-- Kontainer Utama: Menyusun elemen secara vertikal dengan padding 16dp -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Judul Dashboard: Menampilkan teks sapaan atau nama modul -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="24dp"
            android:text="Dashboard Kasir"
            android:textColor="#333333"
            android:textSize="22sp"
            android:textStyle="bold" />

        <!-- Menu Grid: Menyusun tombol menu dalam format kotak (grid) 2 kolom -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:alignmentMode="alignMargins"
            android:columnCount="2">

            <!-- Menu Transaksi: Tombol untuk masuk ke halaman penjualan -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardTransaksi"
                style="@style/Widget.MaterialComponents.CardView"
                android:layout_width="0dp"
                android:layout_height="130dp"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                    android:gravity="center" android:orientation="vertical">
                    <ImageView android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_cart" app:tint="#0D47A1"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="Transaksi" android:textStyle="bold"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Menu Retur: Tombol untuk memproses pengembalian barang -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardRetur"
                android:layout_width="0dp"
                android:layout_height="130dp"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                    android:gravity="center" android:orientation="vertical">
                    <ImageView android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_retur" app:tint="#0D47A1"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="Retur" android:textStyle="bold"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Menu Mutasi: Tombol untuk kirim/terima barang antar toko -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardMutasi"
                android:layout_width="0dp"
                android:layout_height="130dp"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                    android:gravity="center" android:orientation="vertical">
                    <ImageView android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_truck" app:tint="#0D47A1"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="Mutasi" android:textStyle="bold"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Menu Cek Stok: Tombol untuk melihat sisa stok produk -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCekStok"
                android:layout_width="0dp"
                android:layout_height="130dp"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                    android:gravity="center" android:orientation="vertical">
                    <ImageView android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_stok" app:tint="#0D47A1"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="Cek Stok" android:textStyle="bold"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Menu Update Promo: Sinkronisasi data promo terbaru dari server -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardUpdatePromo"
                android:layout_width="0dp"
                android:layout_height="130dp"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                    android:gravity="center" android:orientation="vertical">
                    <ImageView android:layout_width="40dp" android:layout_height="40dp" android:src="@android:drawable/stat_notify_sync" app:tint="#0D47A1"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="Update Promo" android:textStyle="bold"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Menu Tutup Toko: Proses closing shift dan cetak laporan akhir -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardTutupToko"
                android:layout_width="0dp"
                android:layout_height="130dp"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                app:cardBackgroundColor="#FFEBEE"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                    android:gravity="center" android:orientation="vertical">
                    <ImageView android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_close_store" app:tint="#D32F2F"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="Tutup Toko" android:textColor="#D32F2F" android:textStyle="bold"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </GridLayout>

        <!-- Tombol Laporan: Tombol tambahan yang hanya muncul untuk otorisasi tertentu -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLihatLaporan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:padding="12dp"
            android:text="Lihat Laporan (Leader Only)"
            android:visibility="gone"
            app:cornerRadius="12dp"
            app:icon="@android:drawable/ic_menu_today" />
    </LinearLayout>
</ScrollView>